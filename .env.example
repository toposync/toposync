# Local dev ports for a second Toposync instance
TOPOSYNC_BACKEND_PORT=8100
TOPOSYNC_FRONTEND_PORT=5174
TOPOSYNC_PROCESSING_PORT=9101
TOPOSYNC_DATA_DIR=.toposync-data
# Auth mode: enforced (default) | bypass (dev/e2e/curl)
TOPOSYNC_AUTH_MODE=enforced
# Auth cookies: auto (default) | true (HTTPS-only) | false
TOPOSYNC_AUTH_COOKIE_SECURE=auto
# Password hashing (scrypt) parameters used for NEW/updated passwords (defaults shown):
# TOPOSYNC_AUTH_SCRYPT_N=16384
# TOPOSYNC_AUTH_SCRYPT_R=8
# TOPOSYNC_AUTH_SCRYPT_P=1
