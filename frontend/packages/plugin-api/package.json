{
  "name": "@toposync/plugin-api",
  "version": "0.3.0",
  "description": "Public TypeScript contract for Toposync frontend extensions.",
  "license": "MIT",
  "sideEffects": false,
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "basePath.js",
    "basePath.d.ts",
    "index.js",
    "index.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.167.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run typecheck"
  }
}
